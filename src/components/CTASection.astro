---
const {
  title,
  text,
  primaryLabel = "Donate",
  primaryHref = "/donate/",
  primaryTarget,
  primaryRel,
  secondaryLabel,
  secondaryHref,
  secondaryTarget,
  secondaryRel,
  tertiaryLabel,
  tertiaryHref,
  tertiaryTarget,
  tertiaryRel
} = Astro.props;
---

<section class="cta-band">
  <div class="container cta-inner">
    <div>
      <p class="eyebrow">Support rescue work</p>
      <h2>{title}</h2>
      <p>{text}</p>
    </div>
    <div class="button-row">
      <a class="button primary" href={primaryHref} target={primaryTarget} rel={primaryRel}>{primaryLabel}</a>
      {secondaryLabel && <a class="button secondary" href={secondaryHref} target={secondaryTarget} rel={secondaryRel}>{secondaryLabel}</a>}
      {tertiaryLabel && <a class="button secondary" href={tertiaryHref} target={tertiaryTarget} rel={tertiaryRel}>{tertiaryLabel}</a>}
    </div>
  </div>
</section>

<style>
  .cta-band {
    background:
      linear-gradient(135deg, rgba(232, 180, 72, 0.18), transparent 38%),
      var(--color-black);
    color: var(--color-ivory);
    padding: 54px 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .cta-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: center;
  }

  .cta-band .eyebrow {
    color: var(--color-gold);
  }

  .cta-band p {
    max-width: 620px;
    margin-top: 1rem;
    color: var(--color-ink-soft);
  }

  @media (max-width: 760px) {
    .cta-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
