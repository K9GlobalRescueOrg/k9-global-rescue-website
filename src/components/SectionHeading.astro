---
const { eyebrow, title, text, align = "left" } = Astro.props;
---

<div class={`section-heading ${align}`}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {text && <p class="lead">{text}</p>}
</div>

<style>
  .section-heading {
    max-width: 720px;
    margin-bottom: 1.65rem;
  }

  .section-heading.center {
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .section-heading .lead {
    margin-top: 0.85rem;
  }
</style>
