---
const footerNav = [
  { label: "Korea & Asia", href: "/korea-asia/" },
  { label: "Ukraine", href: "/ukraine/" },
  { label: "Disaster Relief", href: "/disaster-relief/" },
  { label: "Partners", href: "/partners/" },
  { label: "Contact", href: "/contact/" }
];
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <a class="footer-brand" href="/">K9 Global Rescue</a>
      <p>
        A mission-driven rescue nonprofit working with volunteers and partners for animals
        in crisis around the world.
      </p>
      <p class="small">Content and donation links are placeholders pending K9GR review.</p>
    </div>
    <div>
      <h2>Explore</h2>
      <div class="footer-links">
        {footerNav.map((item) => <a href={item.href}>{item.label}</a>)}
      </div>
    </div>
    <div>
      <h2>Help the Mission</h2>
      <div class="footer-links">
        <a href="/donate/">Donate</a>
        <a href="/volunteer/">Volunteer</a>
        <a href="/media/">Media / News</a>
      </div>
    </div>
  </div>
  <div class="container footer-bottom">
    <span>Copyright {new Date().getFullYear()} K9 Global Rescue.</span>
    <span>Netlify-ready static Astro site.</span>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-ink);
    color: #fff;
    padding: 58px 0 26px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 0.7fr 0.7fr;
    gap: 2rem;
  }

  .footer-brand {
    display: inline-block;
    margin-bottom: 1rem;
    color: #fff;
    font-size: 1.4rem;
    font-weight: 900;
    text-decoration: none;
  }

  .site-footer p {
    max-width: 560px;
    color: rgba(255, 255, 255, 0.74);
  }

  .small {
    font-size: 0.9rem;
  }

  .site-footer h2 {
    margin-bottom: 1rem;
    color: var(--color-gold);
    font-size: 1rem;
  }

  .footer-links {
    display: grid;
    gap: 0.55rem;
  }

  .footer-links a {
    color: rgba(255, 255, 255, 0.82);
    text-decoration: none;
  }

  .footer-links a:hover {
    color: #fff;
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.8rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.9rem;
  }

  @media (max-width: 760px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
