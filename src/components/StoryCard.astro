---
const {
  title,
  text,
  href,
  tag = "Rescue story",
  image,
  imageAlt = "",
  imagePosition = "center 22%"
} = Astro.props;
---

<article class="story-card">
  {image ? (
    <img class="story-image" src={image} alt={imageAlt} style={`object-position: ${imagePosition};`} loading="lazy" decoding="async" />
  ) : (
    <div class="story-image fallback" aria-hidden="true"></div>
  )}
  <div class="story-copy">
    <span>{tag}</span>
    <h3>{title}</h3>
    <p>{text}</p>
    {href && <a href={href}>Read story</a>}
  </div>
</article>

<style>
  .story-card {
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: #090a07;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.32);
    color: var(--color-ivory);
  }

  .story-image {
    width: 100%;
    height: clamp(220px, 28vw, 280px);
    display: block;
    object-fit: cover;
  }

  .story-image.fallback {
    background:
      linear-gradient(135deg, rgba(0, 0, 0, 0.9), rgba(232, 180, 72, 0.18)),
      radial-gradient(circle at 24% 18%, rgba(232, 180, 72, 0.22), transparent 28%),
      #050604;
    background-position: center;
    background-size: cover;
  }

  .story-image.fallback::after {
    content: "K9";
    display: grid;
    min-height: 180px;
    place-items: center;
    color: rgba(232, 180, 72, 0.32);
    font-size: 4rem;
    font-weight: 950;
    letter-spacing: 0;
  }

  .story-copy {
    padding: 1.25rem;
  }

  .story-copy span {
    display: inline-block;
    margin-bottom: 0.75rem;
    color: var(--color-accent);
    font-size: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .story-copy p {
    color: var(--color-ink-soft);
    margin-bottom: 0.75rem;
  }

  .story-copy a {
    color: var(--color-accent);
    font-weight: 900;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
</style>
