---
const navItems = [
  { label: "Mission", href: "/mission/" },
  { label: "About", href: "/about/" },
  { label: "Team", href: "/meet-the-team/" },
  { label: "Volunteer", href: "/volunteer/" },
  { label: "Operations", href: "/operations/" },
  { label: "Stories", href: "/rescue-stories/" },
  { label: "Media", href: "/media/" },
  { label: "Partners", href: "/partners/" }
];
---

<header class="site-header">
  <div class="topline">
    <div class="container">United States 501(c)(3) nonpartisan nonprofit and EU registered NGO</div>
  </div>
  <nav class="nav container" aria-label="Primary navigation">
    <a class="brand" href="/" aria-label="K9 Global Rescue home">
      <span class="brand-mark">
        <img src="/assets/k9-global-rescue-logo.png" alt="" loading="eager" decoding="async" />
      </span>
      <span>
        <strong>K9 Global Rescue</strong>
        <small>For all without a voice</small>
      </span>
    </a>
    <input class="nav-toggle" id="nav-toggle" type="checkbox" aria-label="Toggle navigation" />
    <label class="nav-toggle-label" for="nav-toggle"><span></span><span></span><span></span></label>
    <div class="nav-links">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href="/donate/" class="nav-donate">Donate</a>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #000000;
    border-bottom: 1px solid rgba(232, 180, 72, 0.38);
    backdrop-filter: blur(16px);
  }

  .topline {
    background: #050604;
    color: #e8b448;
    font-size: 0.82rem;
    font-weight: 700;
    text-align: center;
  }

  .topline .container {
    padding: 0.45rem 0;
  }

  .nav {
    min-height: 78px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: #f5e9d0;
    text-decoration: none;
  }

  .brand-mark {
    display: inline-grid;
    width: 92px;
    height: 58px;
    place-items: center;
    border-radius: var(--radius);
    border: 1px solid rgba(232, 180, 72, 0.5);
    background: #000000;
    overflow: hidden;
  }

  .brand-mark img {
    width: 86px;
    height: 52px;
    object-fit: contain;
    object-position: center;
  }

  .brand strong {
    font-weight: 900;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .brand strong,
  .brand small {
    display: block;
  }

  .brand small {
    color: #e8b448;
    font-size: 0.78rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.12rem;
  }

  .nav-links a {
    border-radius: var(--radius);
    padding: 0.6rem 0.58rem;
    color: #d9c8a7;
    font-size: 0.9rem;
    font-weight: 800;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .nav-links a:hover {
    background: rgba(232, 180, 72, 0.1);
    color: var(--color-gold);
  }

  .nav-links .nav-donate {
    margin-left: 0.25rem;
    background: #e8b448;
    color: #000000;
  }

  .nav-toggle,
  .nav-toggle-label {
    display: none;
  }

  @media (max-width: 940px) {
    .nav {
      min-height: 70px;
    }

    .nav-toggle-label {
      display: inline-grid;
      width: 46px;
      height: 46px;
      place-items: center;
      border: 1px solid rgba(232, 180, 72, 0.42);
      border-radius: var(--radius);
      background: rgba(232, 180, 72, 0.06);
    }

    .nav-toggle-label span {
      display: block;
      width: 22px;
      height: 2px;
      background: #e8b448;
    }

    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      display: none;
      padding: 0.8rem 1rem 1rem;
      border-bottom: 1px solid var(--color-border);
      background: #000000;
      box-shadow: var(--shadow-soft);
    }

    .nav-links a {
      display: block;
      padding: 0.85rem;
    }

    .nav-toggle:checked ~ .nav-links {
      display: grid;
    }
  }
</style>
