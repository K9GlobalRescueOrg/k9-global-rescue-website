---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProgramCard from "../components/ProgramCard.astro";

const pillars = [
  ["Global Animal Rescue", "Rescue operations for animals in urgent need."],
  ["Disaster Relief", "Supplies, transport, coordination, and crisis response."],
  ["Ending Cruelty And Dog Meat Trade", "Rescue and advocacy for dogs facing severe cruelty."],
  ["Medical Care And Disease Mitigation", "Veterinary care, vaccination, spay/neuter, and health support."],
  ["Transport And Adoption Support", "Moving rescued animals toward safety, care, and placement."],
  ["Military And International Programs", "Careful cooperation with service-connected and global partners."],
  ["Sanctuary And Rehabilitation", "Recovery support for abused, disabled, older, or traumatized animals."],
  ["Wildlife Trafficking Advocacy", "Anti-trafficking and anti-poaching advocacy for animals without a voice."]
];
---

<Layout title="Our Mission" description="K9 Global Rescue mission pillars for rescue, relief, medical care, transport, sanctuary support, and advocacy.">
  <Hero
    eyebrow="Our Mission"
    title="Rescue, Relief, Advocacy, And Recovery."
    text="K9GR works for animals in crisis through field operations, partner support, medical care, transport, and advocacy."
    primaryLabel="Global Operations"
    primaryHref="/operations/"
    secondaryLabel="Donate"
    secondaryHref="/donate/"
  />

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Mission pillars"
        title="The Work At A Glance."
        text="K9GR’s mission spans rescue, relief, care, transport, recovery, and advocacy."
      />
      <div class="grid cards">
        {pillars.map(([title, text]) => <ProgramCard title={title} text={text} href="/operations/" label="View operations" />)}
      </div>
    </div>
  </section>
</Layout>
