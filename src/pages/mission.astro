---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProgramCard from "../components/ProgramCard.astro";

const focusAreas = [
  [
    "Rescue & Crisis Support",
    "Supporting animals facing urgent danger, displacement, or neglect."
  ],
  [
    "Transport & Safe Placement",
    "Helping move animals toward care, shelter, rescue partners, and adoption pathways."
  ],
  [
    "Global Partner Support",
    "Working with trusted partners, volunteers, and field teams to support rescue efforts across borders."
  ]
];
---

<Layout title="Our Mission" description="K9 Global Rescue focuses on animals in crisis, rescue coordination, transport, medical care, emergency support, and trusted partner work.">
  <Hero
    eyebrow="Our Mission"
    title="Rescue, Relief, Advocacy, And Recovery."
    text="K9GR works for animals in crisis through field operations, partner support, medical care, transport, and advocacy."
    primaryLabel="Global Operations"
    primaryHref="/operations/"
    secondaryLabel="Donate"
    secondaryHref="/donate/"
  />

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Our focus"
        title="Our Focus"
        text="K9 Global Rescue focuses on animals in crisis, emergency support, rescue coordination, transport, medical care, and trusted partner work where help is needed most."
      />
      <div class="grid cards">
        {focusAreas.map(([title, text]) => <ProgramCard title={title} text={text} href="/operations/" label="Learn more" />)}
      </div>
    </div>
  </section>
</Layout>
