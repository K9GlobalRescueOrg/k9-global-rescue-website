---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import StoryCard from "../components/StoryCard.astro";

const stories = [
  ["Gracie", "A featured rescue story from the Korea and Asia program area."],
  ["Apollo & Juno", "A rescue journey connected to care, transport, and recovery."],
  ["Jesse", "A story centered on survival, rehabilitation, and safety."],
  ["Ukraine Rescue Stories", "Field updates and rescue stories connected to Ukraine support."],
  ["Korea Rescue Stories", "Stories and images from rescue work in Korea and Asia."]
];
---

<Layout title="Rescue Stories" description="K9 Global Rescue story index for Gracie, Apollo and Juno, Jesse, Ukraine rescue stories, and Korea rescue stories.">
  <Hero
    eyebrow="Rescue Stories"
    title="Individual Lives At The Center Of The Mission."
    text="Rescue stories will be shared as public updates become available."
    primaryLabel="Donate"
    primaryHref="/donate/"
    secondaryLabel="Korea & Asia"
    secondaryHref="/korea-asia/"
  />

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Story library"
        title="Stories From The Work."
        text="Follow individual rescue journeys, recovery updates, and regional field stories."
      />
      <div class="grid cards">
        {stories.map(([title, text]) => <StoryCard title={title} text={text} />)}
      </div>
    </div>
  </section>
</Layout>
