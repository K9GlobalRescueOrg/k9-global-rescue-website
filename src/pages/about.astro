---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CTASection from "../components/CTASection.astro";
import QuoteBand from "../components/QuoteBand.astro";
---

<Layout title="About" description="Learn who K9 Global Rescue is and how its volunteer-led global rescue network supports animals in crisis.">
  <Hero
    eyebrow="About K9GR"
    title="A Volunteer-Led Network For Animals Without A Voice."
    text="K9 Global Rescue is a United States 501(c)(3) nonprofit and EU registered NGO working with volunteers and rescue partners."
    primaryLabel="Our Mission"
    primaryHref="/mission/"
    secondaryLabel="Contact"
    secondaryHref="/contact/"
  />

  <section class="section">
    <div class="container split">
      <div>
        <SectionHeading
          eyebrow="Who we are"
          title="A Practical Rescue Network."
          text="Veterans, volunteers, medical professionals, first responders, and advocates support the mission through partner-led work."
        />
        <a class="button secondary" href="/meet-the-team/">Meet The Executive Staff Team</a>
      </div>
      <div class="panel text-panel">
        <h3>Credibility Note</h3>
        <p>K9 Global Rescue presents its nonprofit and NGO identity clearly so donors, volunteers, partners, and media understand the organization.</p>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <SectionHeading
        eyebrow="Organization"
        title="We Stand As One, For All Without A Voice."
        text="About stays focused on the organization. Executive Staff Team profiles live on the dedicated team page."
      />
      <div class="grid cards">
        <div class="panel text-panel">
          <h3>Urgent Needs</h3>
          <p>Focused on rescue, relief, transport, and care.</p>
        </div>
        <div class="panel text-panel">
          <h3>Partner-Led Work</h3>
          <p>Built around trusted local and international coordination.</p>
        </div>
        <div class="panel text-panel">
          <h3>Donor Clarity</h3>
          <p>Donation pages explain what support can fund and direct current giving questions to the team.</p>
        </div>
        <div class="panel text-panel">
          <h3>Meet The Executive Staff Team</h3>
          <p>Jon Barocas serves as Executive Director. The broader Executive Staff Team supports communications, development, adoptions, documentation, and field work.</p>
          <a class="button light" href="/meet-the-team/">View Executive Staff</a>
        </div>
      </div>
    </div>
  </section>

  <QuoteBand
    eyebrow="Belief statement"
    support="A focused reminder behind the rescue, relief, transport, and care work."
    compact
  />

  <CTASection
    title="Know The Mission. Choose A Path."
    text="Read the mission, volunteer, or support rescue operations."
    primaryLabel="Read the Mission"
    primaryHref="/mission/"
    secondaryLabel="Volunteer"
    secondaryHref="/volunteer/"
  />
</Layout>
