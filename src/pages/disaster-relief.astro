---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CTASection from "../components/CTASection.astro";
---

<Layout title="Disaster Relief" description="K9 Global Rescue disaster relief page for emergency response, transport, supplies, partner support, and crisis deployments.">
  <Hero
    eyebrow="Disaster Relief"
    title="Emergency Support When Animals And Communities Are In Crisis."
    text="Response coordination, supplies, transport, partner support, and careful crisis deployment."
    primaryLabel="Donate"
    primaryHref="/donate/"
    secondaryLabel="Contact"
    secondaryHref="/contact/"
  />

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Response areas"
        title="Practical Relief Support."
        text="Clear support areas without unverified response promises."
      />
      <div class="grid cards">
        <div class="panel text-panel"><h3>Emergency Response</h3><p>Urgent support during disasters and crisis events.</p></div>
        <div class="panel text-panel"><h3>Transport</h3><p>Moving animals, supplies, and relief resources.</p></div>
        <div class="panel text-panel"><h3>Supplies</h3><p>Food, medical supplies, shelter materials, and essentials.</p></div>
        <div class="panel text-panel"><h3>Partner Support</h3><p>Coordination with rescues, clinics, shelters, and relief groups.</p></div>
      </div>
    </div>
  </section>

  <CTASection
    title="Preparedness Depends On People Ready To Help."
    text="Support emergency response work through donations, volunteer interest, and partner inquiries."
    secondaryLabel="Volunteer"
    secondaryHref="/volunteer/"
  />
</Layout>
