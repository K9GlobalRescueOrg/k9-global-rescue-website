---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { getCollection } from "astro:content";

const news = await getCollection("news");
---

<Layout title="Media / News" description="K9 Global Rescue media, news, Dog Warriors features, field updates, rescue stories, and video content.">
  <Hero
    eyebrow="Media / News"
    title="A Clearer Home For Films, Videos, And Field Updates."
    text="Follow K9 Global Rescue’s field updates, rescue stories, and media features."
    primaryLabel="Contact"
    primaryHref="/contact/"
    secondaryLabel="Rescue Stories"
    secondaryHref="/rescue-stories/"
  />

  <section class="section">
    <div class="container split">
      <div>
        <SectionHeading
          eyebrow="Media feature"
          title="Dog Warriors"
          text="Dog Warriors media features connect viewers with rescue work, field documentation, and the people behind the mission."
        />
      </div>
      <div class="panel text-panel">
        <h3>YouTube Channel</h3>
        <p>Video updates and field media can be shared here as new public content becomes available.</p>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <SectionHeading
        eyebrow="Updates"
        title="Field Updates And News."
        text="Follow rescue stories, media features, and organization updates."
      />
      <div class="grid cards">
        {news.map((item) => (
          <article class="panel text-panel">
            <p class="eyebrow">News</p>
            <h3>{item.data.title}</h3>
            <p>{item.data.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
