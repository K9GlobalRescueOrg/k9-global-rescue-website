---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { getCollection } from "astro:content";

const news = await getCollection("news");
---

<Layout title="Media / News" description="K9 Global Rescue media, news, Dog Warriors features, field updates, rescue stories, and video content.">
  <Hero
    eyebrow="Media / News"
    title="A Clearer Home For Films, Videos, And Field Updates."
    text="Follow K9 Global Rescue’s field updates, rescue stories, and media features."
    primaryLabel="Contact"
    primaryHref="/contact/"
    secondaryLabel="Rescue Stories"
    secondaryHref="/rescue-stories/"
  />

  <section class="section">
    <div class="container">
      <article class="documentary-feature">
        <div class="documentary-copy">
          <p class="eyebrow">Featured Documentary</p>
          <h2>Dog Warriors</h2>
          <p>
            Dog Warriors offers a closer look at the rescue work, field realities, and people behind K9 Global Rescue. The film follows the organization’s efforts to help animals facing danger, displacement, and neglect, while showing the urgency and complexity of rescue work across borders.
          </p>
          <a
            class="button primary"
            href="https://www.amazon.com/Dog-Warriors-Andrew-Abrahams/dp/B0FR528NHR"
            target="_blank"
            rel="noopener noreferrer"
          >
            Watch on Amazon
          </a>
        </div>
        <div class="documentary-frame" aria-label="Dog Warriors documentary feature">
          <span>Available on Amazon</span>
          <strong>Dog Warriors</strong>
          <small>K9 Global Rescue documentary feature</small>
        </div>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div>
        <SectionHeading
          eyebrow="Field media"
          title="Videos And Field Updates."
          text="Video updates and field media can be shared as approved public content is added."
        />
      </div>
      <div class="panel text-panel">
        <h3>Media Inquiries</h3>
        <p>For interviews, documentary inquiries, or field media questions, use the general contact form.</p>
        <a class="button secondary" href="/contact/">Contact</a>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <SectionHeading
        eyebrow="Updates"
        title="Field Updates And News."
        text="Follow rescue stories, media features, and organization updates."
      />
      <div class="grid cards">
        {news.map((item) => (
          <article class="panel text-panel">
            <p class="eyebrow">News</p>
            <h3>{item.data.title}</h3>
            <p>{item.data.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .documentary-feature {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: stretch;
    overflow: hidden;
    border: 1px solid rgba(232, 180, 72, 0.34);
    border-radius: var(--radius);
    background:
      linear-gradient(135deg, rgba(232, 180, 72, 0.14), rgba(232, 180, 72, 0.02) 42%),
      #090a07;
    box-shadow: var(--shadow-soft);
    color: var(--color-ivory);
  }

  .documentary-copy {
    padding: clamp(1.35rem, 3vw, 2rem);
  }

  .documentary-copy h2 {
    margin-bottom: 1rem;
    color: var(--color-ivory);
  }

  .documentary-copy p:not(.eyebrow) {
    max-width: 68ch;
    margin-bottom: 1.35rem;
    color: var(--color-ink-soft);
    font-size: 1.04rem;
    line-height: 1.65;
  }

  .documentary-frame {
    position: relative;
    display: grid;
    min-height: 340px;
    align-content: end;
    padding: 1.25rem;
    border-left: 1px solid rgba(232, 180, 72, 0.26);
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.04), rgba(0, 0, 0, 0.86)),
      radial-gradient(circle at 72% 18%, rgba(232, 180, 72, 0.28), transparent 28%),
      linear-gradient(145deg, #15110a, #020202 62%);
    isolation: isolate;
  }

  .documentary-frame::before {
    content: "K9";
    position: absolute;
    right: -0.12em;
    bottom: -0.18em;
    z-index: -1;
    color: rgba(232, 180, 72, 0.16);
    font-size: clamp(9rem, 18vw, 16rem);
    font-weight: 950;
    line-height: 0.8;
  }

  .documentary-frame span,
  .documentary-frame small {
    color: var(--color-ink-soft);
    font-weight: 850;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .documentary-frame strong {
    margin: 0.35rem 0;
    color: var(--color-gold);
    font-size: clamp(2rem, 4vw, 3.6rem);
    line-height: 0.92;
    text-transform: uppercase;
  }

  @media (max-width: 820px) {
    .documentary-feature {
      grid-template-columns: 1fr;
    }

    .documentary-frame {
      min-height: 260px;
      border-left: 0;
      border-top: 1px solid rgba(232, 180, 72, 0.26);
    }
  }
</style>
