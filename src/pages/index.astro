---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProgramCard from "../components/ProgramCard.astro";
import StoryCard from "../components/StoryCard.astro";
import CTASection from "../components/CTASection.astro";
import QuoteBand from "../components/QuoteBand.astro";

const programs = [
  {
    title: "Korea & Asia",
    text: "Dog meat trade rescue, rehabilitation, transport, and advocacy.",
    href: "/korea-asia/"
  },
  {
    title: "Ukraine",
    text: "Humanitarian aid, animal medical support, supplies, and evacuations.",
    href: "/ukraine/"
  },
  {
    title: "Disaster Relief",
    text: "Emergency supplies, transport, partner coordination, and response support.",
    href: "/disaster-relief/"
  },
  {
    title: "Rescue Stories",
    text: "Rescue stories, project updates, and recovery journeys.",
    href: "/rescue-stories/"
  },
  {
    title: "Volunteer Network",
    text: "Volunteer interest, logistics support, field skills, and partner needs.",
    href: "/volunteer/"
  }
];

const actions = [
  ["Rescue Animals In Crisis", "Rapid support for dogs and animals facing urgent harm."],
  ["Support Global Partners", "Work with rescue groups, shelters, clinics, and field teams."],
  ["Move Aid And Medical Support", "Food, supplies, transport, veterinary care, and evacuation help."],
  ["Help Animals Reach Safety", "Recovery, rehabilitation, transport, and adoption support."]
];
---

<Layout
  title="K9 Global Rescue"
  description="K9 Global Rescue is a mission-driven nonprofit working globally for animals in crisis through rescue, relief, transport, medical care, and advocacy."
>
  <Hero
    eyebrow="United States 501(c)(3) nonprofit and EU registered NGO"
    title="Global Rescue For Animals In Crisis."
    text="K9 Global Rescue helps animals facing war, disaster, cruelty, and abandonment through rescue operations, aid, medical support, transport, and partner networks."
    primaryLabel="Donate"
    primaryHref="/donate/"
    secondaryLabel="Volunteer"
    secondaryHref="/volunteer/"
    tertiaryLabel="See Our Work"
    tertiaryHref="/operations/"
  />

  <CTASection
    title="Give. Volunteer. Move Rescue Forward."
    text="Your next step should be simple: fund the work, join the volunteer network, or learn where K9GR operates."
    primaryLabel="Donate"
    primaryHref="/donate/"
    secondaryLabel="Volunteer"
    secondaryHref="/volunteer/"
  />

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="What we do"
        title="Operational Help For Animals Without A Voice."
        text="Short, direct support for urgent rescue needs."
      />
      <div class="grid cards">
        {actions.map(([title, text]) => (
          <div class="panel text-panel action-card">
            <h3>{title}</h3>
            <p>{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <QuoteBand
    support="Every rescue begins with one life. Every safe transport, medical case, and partner mission starts there."
  />

  <section class="section alt">
    <div class="container">
      <SectionHeading
        eyebrow="Focus areas"
        title="Where The Work Happens."
        text="Choose a program area for rescue, relief, transport, advocacy, and support pathways."
      />
      <div class="grid cards">
        {programs.map((program) => <ProgramCard {...program} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Rescue stories"
        title="Individual Rescue Stories."
        text="Gracie, Apollo and Juno, Jesse, Ukraine, and Korea stories will be shared as updates become available."
      />
      <div class="grid cards">
        <StoryCard
          title="Gracie"
          text="A rescue story from the Korea and Asia program area."
          href="/rescue-stories/"
        />
        <StoryCard
          title="Apollo & Juno"
          text="A rescue journey connected to the organization’s global work."
          href="/rescue-stories/"
        />
        <StoryCard
          title="Ukraine Rescue Stories"
          text="Field updates and rescue stories connected to Ukraine support."
          href="/rescue-stories/"
        />
      </div>
    </div>
  </section>

  <CTASection
    title="Rescue Work Needs Fast Support."
    text="Donations help support rescue operations, medical care, food, shelter, transport, and emergency response."
    primaryLabel="Donate"
    primaryHref="/donate/"
    secondaryLabel="See Our Work"
    secondaryHref="/operations/"
  />
</Layout>

<style>
  .action-card {
    min-height: 0;
  }
</style>
