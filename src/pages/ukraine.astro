---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CTASection from "../components/CTASection.astro";
---

<Layout title="Ukraine" description="K9 Global Rescue Ukraine page for humanitarian aid, animal medical aid, evacuations, pet supplies, and rescue partner support.">
  <Hero
    eyebrow="Ukraine"
    title="Standing With The People And Animals Of Ukraine."
    text="Humanitarian support, animal medical aid, supplies, evacuations, and rescue partner support."
    primaryLabel="Donate"
    primaryHref="/donate/"
    secondaryLabel="Volunteer"
    secondaryHref="/volunteer/"
  />

  <section class="section">
    <div class="container split">
      <div>
        <SectionHeading
          eyebrow="Relief and rescue"
          title="Support Where People And Animals Are In Crisis."
          text="Aid, supplies, transport support, and partner coordination for people and animals affected by crisis."
        />
        <ul class="check-list">
          <li>Humanitarian aid, food, and supplies.</li>
          <li>Animal medical aid and evacuation support.</li>
          <li>Rescue partner, clinic, and shelter coordination.</li>
          <li>Field updates as reliable information becomes available.</li>
        </ul>
      </div>
      <div class="visual-block ukraine"></div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="note">
        <strong>Current Information:</strong> For the latest Ukraine support details, contact the K9 Global Rescue team.
      </div>
    </div>
  </section>

  <CTASection
    title="Support Emergency Aid And Animal Rescue."
    text="Donations help support humanitarian aid, animal medical support, supplies, evacuations, and rescue partner work."
  />
</Layout>
