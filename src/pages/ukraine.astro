---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CTASection from "../components/CTASection.astro";
---

<Layout title="Ukraine" description="K9 Global Rescue Ukraine page for humanitarian aid, animal medical aid, evacuations, pet supplies, and rescue partner support.">
  <Hero
    eyebrow="Ukraine"
    title="Standing with the people and animals of Ukraine."
    text="The current site emphasizes humanitarian support, animal rescue, medical aid, pet food and supplies, evacuations, and partner support for communities and animals affected by war."
    primaryLabel="Donate"
    primaryHref="/donate/"
    secondaryLabel="Volunteer"
    secondaryHref="/volunteer/"
  />

  <section class="section">
    <div class="container split">
      <div>
        <SectionHeading
          eyebrow="Relief and rescue"
          title="Support where people and animals are in crisis."
          text="This page keeps the urgent Ukraine theme while removing unverified current trip counts or deployment totals."
        />
        <ul class="check-list">
          <li>Humanitarian aid, food, and supplies for affected communities.</li>
          <li>Animal medical aid, pet food, shelter supplies, and evacuation support.</li>
          <li>Coordination with rescue partners, clinics, shelters, and local support networks.</li>
          <li>Story and update areas for reviewed photos, videos, and field reports.</li>
        </ul>
      </div>
      <div class="visual-block ukraine"></div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="note">
        <strong>Content note:</strong> The current site includes specific place names, rescue
        examples, and dated trip counts. Any numbers, frontline location claims, named
        partners, or current deployment details should be verified before launch.
      </div>
    </div>
  </section>

  <CTASection
    title="Support emergency aid and animal rescue."
    text="Donations can support medical care, food, transport, shelter supplies, evacuation needs, and rescue partner support. Final campaign links must be supplied by K9GR."
  />
</Layout>
