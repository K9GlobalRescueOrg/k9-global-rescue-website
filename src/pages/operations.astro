---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProgramCard from "../components/ProgramCard.astro";

const ops = [
  { title: "Korea & Asia", text: "Dog meat trade rescue, rehabilitation, transport, and advocacy.", href: "/korea-asia/" },
  { title: "Ukraine", text: "Humanitarian aid, animal medical aid, evacuations, and partner support.", href: "/ukraine/" },
  { title: "Disaster Relief", text: "Supplies, transport, crisis response, and partner support.", href: "/disaster-relief/" },
  { title: "Rescue Coordination", text: "Trusted partner work, urgent response paths, and practical support where help is needed most.", href: "/contact/" },
  { title: "Transport And Partner Support", text: "Helping animals move toward care, shelter, rescue partners, and adoption pathways.", href: "/mission/" },
  { title: "Medical Care And Emergency Aid", text: "Support for medical needs, food, supplies, shelter, and emergency response.", href: "/donate/" },
  { title: "Volunteer And Partner Network", text: "Volunteer interest, partner inquiries, logistics support, and field-ready coordination.", href: "/volunteer/" }
];
---

<Layout title="Global Rescue Operations" description="Overview of K9 Global Rescue international rescue work and program areas.">
  <Hero
    variant="operations"
    eyebrow="Global Rescue Operations"
    title="Where K9GR Works."
    text="K9 Global Rescue supports rescue operations, emergency response, transport, and partner-led animal welfare work where help is needed most."
    primaryLabel="Donate"
    primaryHref="/donate/"
    secondaryLabel="Volunteer"
    secondaryHref="/volunteer/"
    backgroundImage="/assets/operations-hero-k9gr-rescue.png"
    backgroundPosition="center center"
    mobileBackgroundPosition="66% center"
  />

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Operations focus"
        title="Where The Mission Is Focused."
        text="Explore current program areas and support lanes for rescue, relief, transport, care, and trusted partner work."
      />
      <div class="grid cards">
        {ops.map((op) => <ProgramCard {...op} />)}
      </div>
    </div>
  </section>
</Layout>
