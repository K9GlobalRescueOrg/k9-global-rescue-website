---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProgramCard from "../components/ProgramCard.astro";

const ops = [
  { title: "Korea & Asia", text: "Dog meat trade rescue, rehabilitation, transport, and advocacy.", href: "/korea-asia/" },
  { title: "Ukraine", text: "Humanitarian aid, animal medical aid, evacuations, and partner support.", href: "/ukraine/" },
  { title: "Middle East", text: "Regional rescue work, partner support, and animal welfare coordination.", href: "/middle-east/" },
  { title: "Disaster Relief", text: "Supplies, transport, crisis response, and partner support.", href: "/disaster-relief/" },
  { title: "Military Programs", text: "Service-connected volunteers, disease mitigation, and working dog support themes.", href: "/military-international-programs/" }
];
---

<Layout title="Global Rescue Operations" description="Overview of K9 Global Rescue international rescue work and program areas.">
  <Hero
    variant="operations"
    eyebrow="Global Rescue Operations"
    title="Where K9GR Works."
    text="Program pages organize international rescue, relief, transport, and advocacy work."
    primaryLabel="Donate"
    primaryHref="/donate/"
    secondaryLabel="Volunteer"
    secondaryHref="/volunteer/"
  />

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Program map"
        title="Where The Mission Is Focused."
        text="Explore the program areas that organize K9GR’s rescue, relief, transport, and advocacy work."
      />
      <div class="grid cards">
        {ops.map((op) => <ProgramCard {...op} />)}
      </div>
    </div>
  </section>
</Layout>
