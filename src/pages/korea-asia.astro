---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import StoryCard from "../components/StoryCard.astro";
import CTASection from "../components/CTASection.astro";
---

<Layout title="Korea & Asia" description="K9 Global Rescue work connected to dog meat trade rescue, farm closures, rehabilitation, transport, and advocacy in Korea and Asia.">
  <Hero
    eyebrow="Korea & Asia"
    title="Rescue and advocacy for dogs facing the meat trade and severe cruelty."
    text="The current site centers K9GR's Asia work on rescue from the dog meat trade, rehabilitation, transport, adoption support, farm closure work, and international advocacy."
    primaryLabel="Support This Work"
    primaryHref="/donate/"
    secondaryLabel="Rescue Stories"
    secondaryHref="/rescue-stories/"
  />

  <section class="section">
    <div class="container split">
      <div>
        <SectionHeading
          eyebrow="Program focus"
          title="From emergency rescue to recovery and advocacy."
          text="This page preserves the core themes from the current site while making them easier to scan and review."
        />
        <ul class="check-list">
          <li>Rescue from dog meat farms, markets, slaughter risk, and severe neglect.</li>
          <li>Medical care, nutrition, rehabilitation, behavior support, and safe shelter.</li>
          <li>Transport and adoption support through approved partners and receiving organizations.</li>
          <li>Advocacy against cruelty and public awareness around the dog meat trade.</li>
        </ul>
      </div>
      <div class="panel text-panel">
        <h3>Verify before launch</h3>
        <p>
          South Korea passed legislation to end the dog meat industry, with implementation
          details and effective dates requiring final fact check before publication. This
          page should not overclaim the current status of enforcement or K9GR's role.
        </p>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <SectionHeading
        eyebrow="Story placeholders"
        title="Featured rescue stories and gallery areas."
        text="The current site highlights Gracie, Apollo, Jesse, and a Korea gallery. These entries are prepared as placeholders pending approved narrative copy and media."
      />
      <div class="grid cards">
        <StoryCard title="Gracie" text="Placeholder for Gracie's rescue, recovery, and life after survival." />
        <StoryCard title="Apollo & Juno" text="Placeholder for Apollo and Juno's rescue journey and outcome." />
        <StoryCard title="Jesse" text="Placeholder for Jesse's story, images, and final reviewed summary." />
        <StoryCard title="Korea Gallery" text="Placeholder for reviewed images documenting rescue and rehabilitation work." />
      </div>
    </div>
  </section>

  <CTASection
    title="Help fund rescue, care, and transport."
    text="Korea and Asia work may require medical treatment, sheltering, rehabilitation, ground logistics, and safe transport. Final campaign links are placeholders until approved."
  />
</Layout>
