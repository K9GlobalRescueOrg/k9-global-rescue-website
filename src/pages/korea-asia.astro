---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import StoryCard from "../components/StoryCard.astro";
import CTASection from "../components/CTASection.astro";
---

<Layout title="Korea & Asia" description="K9 Global Rescue work connected to dog meat trade rescue, farm closures, rehabilitation, transport, and advocacy in Korea and Asia.">
  <Hero
    eyebrow="Korea & Asia"
    title="Rescue And Advocacy For Dogs Facing The Meat Trade And Severe Cruelty."
    text="Rescue, rehabilitation, transport, adoption support, and advocacy connected to the dog meat trade."
    primaryLabel="Support This Work"
    primaryHref="/donate/"
    secondaryLabel="Rescue Stories"
    secondaryHref="/rescue-stories/"
  />

  <section class="section">
    <div class="container split">
      <div>
        <SectionHeading
          eyebrow="Program focus"
          title="From Rescue To Recovery."
          text="Rescue support, recovery care, transport, and advocacy for dogs facing severe cruelty."
        />
        <ul class="check-list">
          <li>Dog meat trade rescue and farm closure support.</li>
          <li>Medical care, rehabilitation, and safe shelter.</li>
          <li>Transport and adoption support through trusted partners.</li>
          <li>Advocacy against cruelty.</li>
        </ul>
      </div>
      <div class="panel text-panel">
        <h3>Advocacy Context</h3>
        <p>K9 Global Rescue supports efforts to end cruelty and help dogs move from danger toward safety.</p>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <SectionHeading
        eyebrow="Rescue stories"
        title="Featured Rescue Stories And Gallery Areas."
        text="Stories and images from this program area will be shared as updates become available."
      />
      <div class="grid cards">
        <StoryCard title="Gracie" text="A featured rescue story from the Korea and Asia program area." />
        <StoryCard title="Apollo & Juno" text="A rescue journey connected to transport, care, and recovery." />
        <StoryCard title="Jesse" text="A story centered on survival, rehabilitation, and safety." />
        <StoryCard title="Korea Gallery" text="Images and updates from rescue work in Korea and Asia." />
      </div>
    </div>
  </section>

  <CTASection
    title="Help Fund Rescue, Care, And Transport."
    text="Donations help support rescue operations, medical care, food, shelter, transport, and emergency response."
  />
</Layout>
