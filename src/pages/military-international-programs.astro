---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CTASection from "../components/CTASection.astro";
---

<Layout title="Military & International Programs" description="K9 Global Rescue military and international programs involving former military volunteers, cooperation, disease mitigation, and retired working dog support.">
  <Hero
    eyebrow="Military & International Programs"
    title="Service Experience Redirected Toward Animal Welfare."
    text="Military-connected volunteers, international cooperation, disease mitigation, and retired working dog themes."
    primaryLabel="Contact"
    primaryHref="/contact/"
    secondaryLabel="Our Mission"
    secondaryHref="/mission/"
  />

  <section class="section">
    <div class="container split">
      <div>
        <SectionHeading
          eyebrow="Careful program framing"
          title="International Cooperation Without Overpromising."
          text="This work is framed around service experience, partner cooperation, and animal welfare support."
        />
        <ul class="check-list">
          <li>Military-connected volunteer and logistics experience.</li>
          <li>Disease mitigation and population health support.</li>
          <li>Service-connected animal transport support themes.</li>
          <li>Retired working dog support themes.</li>
        </ul>
      </div>
      <div class="panel text-panel">
        <h3>Program Inquiries</h3>
        <p>For current information about military-connected or international support work, contact the K9 Global Rescue team.</p>
      </div>
    </div>
  </section>

  <CTASection
    title="Have A Program Or Partner Inquiry?"
    text="Route military, international, rescue, or partner inquiries through contact."
    primaryLabel="Contact"
    primaryHref="/contact/"
  />
</Layout>
