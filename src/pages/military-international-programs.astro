---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CTASection from "../components/CTASection.astro";
---

<Layout title="Military & International Programs" description="K9 Global Rescue military and international programs involving former military volunteers, cooperation, disease mitigation, and retired working dog support.">
  <Hero
    eyebrow="Military & International Programs"
    title="Service experience redirected toward animal welfare."
    text="The current site describes former military volunteers, international cooperation, disease mitigation, service member support, and retired working dog themes. This page uses careful wording pending final program review."
    primaryLabel="Contact"
    primaryHref="/contact/"
    secondaryLabel="Our Mission"
    secondaryHref="/mission/"
  />

  <section class="section">
    <div class="container split">
      <div>
        <SectionHeading
          eyebrow="Careful program framing"
          title="International cooperation without overpromising."
          text="This page should be finalized with approved details about active programs, eligibility, partner agencies, and retired working dog support."
        />
        <ul class="check-list">
          <li>Military-connected volunteers and logistics experience supporting rescue work.</li>
          <li>Disease mitigation, vaccination, spay/neuter, and population health cooperation.</li>
          <li>Support themes for service members seeking to bring adopted animals home.</li>
          <li>Retired working dog support language to verify before launch.</li>
        </ul>
      </div>
      <div class="panel text-panel">
        <h3>Launch review needed</h3>
        <p>
          Avoid implying guaranteed services, agency endorsements, or active government
          partnerships unless K9GR provides current documentation and approved wording.
        </p>
      </div>
    </div>
  </section>

  <CTASection
    title="Have a program or partner inquiry?"
    text="Use the contact page to route military, international, rescue, or partner inquiries to the right K9GR review path."
    primaryLabel="Contact"
    primaryHref="/contact/"
  />
</Layout>
