---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CTASection from "../components/CTASection.astro";
---

<Layout title="Partners" description="K9 Global Rescue partner information for rescue partners, aviation and travel partners, donors, corporate supporters, and inquiries.">
  <Hero
    eyebrow="Partners"
    title="Rescue Work Depends On Trusted Partners."
    text="K9 Global Rescue works through relationships that can support rescue, transport, care, communication, and field needs."
    primaryLabel="Partner Inquiry"
    primaryHref="/contact/"
    secondaryLabel="Donate"
    secondaryHref="/donate/"
  />

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Partner categories"
        title="Ways Partners Can Support The Mission."
      />
      <div class="grid cards">
        <div class="panel text-panel"><h3>Rescue Partners</h3><p>Shelters, clinics, rescues, and field partners.</p></div>
        <div class="panel text-panel"><h3>Aviation And Travel</h3><p>Flight, mileage, travel, and transport support.</p></div>
        <div class="panel text-panel"><h3>Donors And Corporate Supporters</h3><p>Support for rescue needs, field supplies, transport, and emergency response.</p></div>
        <div class="panel text-panel"><h3>Partner Inquiries</h3><p>Route new conversations through contact.</p></div>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <article class="miles-panel">
        <div>
          <p class="eyebrow">Aviation support</p>
          <h2>United Airlines Miles On A Mission</h2>
          <p>
            K9 Global Rescue is listed through United Airlines' Miles on a Mission program. Donated miles can help support travel connected to rescue, transport, and field needs.
          </p>
        </div>
        <a
          class="button primary"
          href="https://donate.mileageplus.com/Charity/Details/3197432"
          target="_blank"
          rel="noopener noreferrer"
        >
          Donate Miles
        </a>
      </article>
    </div>
  </section>

  <CTASection
    title="Interested In Partnering?"
    text="Start rescue, travel, corporate, donor, or media inquiries through contact."
    primaryLabel="Contact"
    primaryHref="/contact/"
  />
</Layout>

<style>
  .miles-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(1.25rem, 4vw, 3rem);
    align-items: center;
    padding: clamp(1.35rem, 4vw, 2.25rem);
    border: 1px solid rgba(232, 180, 72, 0.32);
    border-radius: var(--radius);
    background:
      linear-gradient(135deg, rgba(232, 180, 72, 0.28), transparent 44%),
      #f5e9d0;
    box-shadow: var(--shadow-soft);
  }

  .miles-panel h2 {
    margin-bottom: 0.8rem;
    color: #090a07;
  }

  .miles-panel .eyebrow {
    color: #6d4a09;
  }

  .miles-panel p:not(.eyebrow) {
    max-width: 680px;
    color: #241b0b;
    font-size: 1.05rem;
    line-height: 1.65;
  }

  @media (max-width: 760px) {
    .miles-panel {
      grid-template-columns: 1fr;
    }

    .miles-panel .button {
      justify-self: start;
    }
  }
</style>
