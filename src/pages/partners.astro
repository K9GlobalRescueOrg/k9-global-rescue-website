---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CTASection from "../components/CTASection.astro";
---

<Layout title="Partners" description="K9 Global Rescue partner placeholder page for rescue partners, aviation and travel partners, donors, corporate supporters, and inquiries.">
  <Hero
    eyebrow="Partners"
    title="Rescue work depends on trusted partners."
    text="This placeholder page is ready for rescue partners, aviation and travel partners, donors, corporate supporters, and partner inquiry pathways once K9GR approves public names and details."
    primaryLabel="Partner Inquiry"
    primaryHref="/contact/"
    secondaryLabel="Donate"
    secondaryHref="/donate/"
  />

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Partner categories"
        title="Prepared for approved partner content."
      />
      <div class="grid cards">
        <div class="panel text-panel"><h3>Rescue partners</h3><p>Placeholder for shelters, clinics, rescues, and field partners approved for public listing.</p></div>
        <div class="panel text-panel"><h3>Aviation and travel</h3><p>Placeholder for flight, travel, mileage, and transport partners.</p></div>
        <div class="panel text-panel"><h3>Donors and corporate supporters</h3><p>Placeholder for approved donor and company acknowledgments.</p></div>
        <div class="panel text-panel"><h3>Partner inquiries</h3><p>Route new partnership conversations through the contact page until a final form exists.</p></div>
      </div>
    </div>
  </section>

  <CTASection
    title="Interested in partnering?"
    text="Use the contact form to start a rescue, travel, corporate, donor, or media partnership inquiry."
    primaryLabel="Contact"
    primaryHref="/contact/"
  />
</Layout>
