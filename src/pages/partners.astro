---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CTASection from "../components/CTASection.astro";
---

<Layout title="Partners" description="K9 Global Rescue partner information for rescue partners, aviation and travel partners, donors, corporate supporters, and inquiries.">
  <Hero
    eyebrow="Partners"
    title="Rescue Work Depends On Trusted Partners."
    text="K9 Global Rescue works through relationships that can support rescue, transport, care, communication, and field needs."
    primaryLabel="Partner Inquiry"
    primaryHref="/contact/"
    secondaryLabel="Donate"
    secondaryHref="/donate/"
  />

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Partner categories"
        title="Ways Partners Can Support The Mission."
      />
      <div class="grid cards">
        <div class="panel text-panel"><h3>Rescue Partners</h3><p>Shelters, clinics, rescues, and field partners.</p></div>
        <div class="panel text-panel"><h3>Aviation And Travel</h3><p>Flight, mileage, travel, and transport support.</p></div>
        <div class="panel text-panel"><h3>Donors And Corporate Supporters</h3><p>Support for rescue needs, field supplies, transport, and emergency response.</p></div>
        <div class="panel text-panel"><h3>Partner Inquiries</h3><p>Route new conversations through contact.</p></div>
      </div>
    </div>
  </section>

  <CTASection
    title="Interested In Partnering?"
    text="Start rescue, travel, corporate, donor, or media inquiries through contact."
    primaryLabel="Contact"
    primaryHref="/contact/"
  />
</Layout>
