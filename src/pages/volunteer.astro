---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CTASection from "../components/CTASection.astro";

const volunteerFormUrl = "https://docs.google.com/forms/d/e/1FAIpQLSfcv8pCy5hDpN8ThFcvmn8T1oJb4ELTZb0I4vEbA4-Yx2wKeA/viewform";
---

<Layout title="Volunteer" description="Volunteer with K9 Global Rescue through field, logistics, admin, media, transport, and professional support opportunities.">
  <Hero
    eyebrow="Volunteer"
    title="Build The Network Before The Next Urgent Call."
    text="Share skills, availability, and experience so K9GR can evaluate possible volunteer fit."
    primaryLabel="Apply to Volunteer"
    primaryHref={volunteerFormUrl}
    primaryTarget="_blank"
    primaryRel="noopener noreferrer"
    secondaryLabel="Ask a Question"
    secondaryHref="/contact/"
  />

  <section class="section">
    <div class="container split">
      <div>
        <SectionHeading
          eyebrow="Ways to help"
          title="Many Forms Of Service Can Support Rescue Work."
          text="Volunteer needs shift with each operation, partner request, and response window."
        />
        <ul class="check-list">
          <li>Field and logistics support.</li>
          <li>Transport, animal handling, fostering, and adoption support.</li>
          <li>Veterinary, medical, and crisis-response expertise.</li>
          <li>Admin, fundraising, media, translation, and events.</li>
        </ul>
      </div>
      <div class="panel text-panel" id="signup">
        <h3>Volunteer Intake</h3>
        <p>Volunteer interest is evaluated by the K9 Global Rescue team. Submitting the form does not guarantee immediate placement or deployment.</p>
        <a class="button primary" href={volunteerFormUrl} target="_blank" rel="noopener noreferrer">Apply to Volunteer</a>
        <p class="question-note">For general questions, use the <a href="/contact/">contact form</a>. For volunteer applications, complete the official volunteer intake form.</p>
      </div>
    </div>
  </section>

  <CTASection
    title="Ready Volunteers Make Response Easier."
    text="For general questions, use the contact form. For volunteer applications, complete the official volunteer intake form."
    primaryLabel="Apply to Volunteer"
    primaryHref={volunteerFormUrl}
    primaryTarget="_blank"
    primaryRel="noopener noreferrer"
    secondaryLabel="Ask a Question"
    secondaryHref="/contact/"
  />
</Layout>

<style>
  .question-note {
    color: var(--color-ink-soft);
    margin: 1rem 0 0;
  }
</style>
