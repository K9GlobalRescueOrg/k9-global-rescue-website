---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
---

<Layout title="Middle East" description="Placeholder page for K9 Global Rescue Middle East rescue work pending final content review.">
  <Hero
    eyebrow="Middle East"
    title="Middle East rescue work."
    text="The current site includes Middle East rescue content. This page is prepared as a credible placeholder until K9GR provides final program copy, images, partners, and active campaign links."
    primaryLabel="Contact"
    primaryHref="/contact/"
    secondaryLabel="Global Operations"
    secondaryHref="/operations/"
  />

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Content review needed"
        title="Program details to verify."
        text="Before launch, K9GR should confirm the scope of current Middle East work, any active partners, approved rescue stories, and any donation or volunteer needs connected to this program area."
      />
    </div>
  </section>
</Layout>
