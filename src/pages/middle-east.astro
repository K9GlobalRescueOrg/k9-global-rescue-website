---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
---

<Layout title="Middle East" description="K9 Global Rescue Middle East rescue work, partner support, and animal welfare coordination.">
  <Hero
    eyebrow="Middle East"
    title="Middle East Rescue Work."
    text="Regional rescue work, partner support, and animal welfare coordination for animals in crisis."
    primaryLabel="Contact"
    primaryHref="/contact/"
    secondaryLabel="Global Operations"
    secondaryHref="/operations/"
  />

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Regional support"
        title="Rescue Work Across Complex Conditions."
        text="For current information about this program area, contact the K9 Global Rescue team."
      />
    </div>
  </section>
</Layout>
